<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ir.permscraft</groupId>
    <artifactId>PermsCraft</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>PermsCraft</name>
    <description>A powerful permission management plugin</description>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <repositories>
        <!-- Paper (includes Bukkit + Spigot API) -->
        <repository>
            <id>papermc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>



        <!-- PlaceholderAPI -->
        <repository>
            <id>placeholderapi</id>
            <url>https://repo.extendedclip.com/content/repositories/placeholderapi/</url>
        </repository>


        <!-- Folia API -->
        <repository>
            <id>foliamc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>

        <!-- Vault -->
        <repository>
            <id>jitpack</id>
            <url>https://jitpack.io</url>
        </repository>
    </repositories>

    <dependencies>

        <!-- Paper API 1.21 (includes Bukkit + Spigot + Paper) -->
        <dependency>
            <groupId>io.papermc.paper</groupId>
            <artifactId>paper-api</artifactId>
            <version>1.21.4-R0.1-SNAPSHOT</version>
            <scope>provided</scope>
        </dependency>


        <!-- Folia API (same repo as Paper; provided at runtime) -->
        <dependency>
            <groupId>dev.folia</groupId>
            <artifactId>folia-api</artifactId>
            <version>1.20.4-R0.1-SNAPSHOT</version>
            <scope>provided</scope>
        </dependency>

        <!-- PlaceholderAPI -->
        <dependency>
            <groupId>me.clip</groupId>
            <artifactId>placeholderapi</artifactId>
            <version>2.11.6</version>
            <scope>provided</scope>
        </dependency>




        <!-- Vault -->
        <dependency>
            <groupId>com.github.MilkBowl</groupId>
            <artifactId>VaultAPI</artifactId>
            <version>1.7</version>
            <scope>provided</scope>
        </dependency>


        <!-- Javalin — embedded HTTP server for REST API -->
        <dependency>
            <groupId>io.javalin</groupId>
            <artifactId>javalin</artifactId>
            <version>6.3.0</version>
            <scope>compile</scope>
        </dependency>

        <!-- Jackson — JSON mapper (used by Javalin + BackupManager) -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.17.2</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-core</artifactId>
            <version>2.17.2</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <version>2.17.2</version>
            <scope>compile</scope>
        </dependency>
        <!-- jackson-module-kotlin: required by Javalin's JavalinJackson mapper -->
        <dependency>
            <groupId>com.fasterxml.jackson.module</groupId>
            <artifactId>jackson-module-kotlin</artifactId>
            <version>2.17.2</version>
            <scope>compile</scope>
        </dependency>

        <!-- Kotlin stdlib: Javalin is written in Kotlin; must be shaded -->
        <dependency>
            <groupId>org.jetbrains.kotlin</groupId>
            <artifactId>kotlin-stdlib</artifactId>
            <version>2.0.21</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.jetbrains.kotlin</groupId>
            <artifactId>kotlin-reflect</artifactId>
            <version>2.0.21</version>
            <scope>compile</scope>
        </dependency>

        <!-- SLF4J API: Javalin uses it for logging (redirect to Bukkit) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>2.0.16</version>
            <scope>compile</scope>
        </dependency>
        <!-- slf4j-jdk14: routes SLF4J → java.util.logging (Bukkit's logger) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-jdk14</artifactId>
            <version>2.0.16</version>
            <scope>compile</scope>
        </dependency>

        <!-- HikariCP (connection pool) -->
        <!-- HikariCP — shaded into jar (no runtime download) -->
        <dependency>
            <groupId>com.zaxxer</groupId>
            <artifactId>HikariCP</artifactId>
            <version>5.1.0</version>
            <scope>compile</scope>
        </dependency>

        <!-- MongoDB Driver -->
        <dependency>
            <groupId>org.mongodb</groupId>
            <artifactId>mongodb-driver-sync</artifactId>
            <version>5.1.4</version>
            <scope>compile</scope>
        </dependency>

        <!-- Jedis (Redis client) -->
        <!-- Jedis — shaded into jar -->
        <dependency>
            <groupId>redis.clients</groupId>
            <artifactId>jedis</artifactId>
            <version>5.1.5</version>
            <scope>compile</scope>
        </dependency>

        <!-- SQLite JDBC -->
        <!-- SQLite JDBC — shaded into jar -->
        <dependency>
            <groupId>org.xerial</groupId>
            <artifactId>sqlite-jdbc</artifactId>
            <version>3.46.1.3</version>
            <scope>compile</scope>
        </dependency>

        <!-- H2 Database -->
        <!-- H2 — shaded into jar -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <version>2.3.232</version>
            <scope>compile</scope>
        </dependency>

        <!-- MySQL Connector -->
        <!-- MySQL Connector — shaded into jar -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>9.1.0</version>
            <scope>compile</scope>
        </dependency>

        <!-- MariaDB Connector/J — shaded into jar -->
        <dependency>
            <groupId>org.mariadb.jdbc</groupId>
            <artifactId>mariadb-java-client</artifactId>
            <version>3.5.8</version>
            <scope>compile</scope>
        </dependency>


        <!-- PostgreSQL Driver -->
        <!-- PostgreSQL — shaded into jar -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.4</version>
            <scope>compile</scope>
        </dependency>

        <!-- ─── Test dependencies ──────────────────────────────────────────── -->

        <!-- JUnit 5 -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.11.3</version>
            <scope>test</scope>
        </dependency>

        <!-- Mockito (for mocking Bukkit / PermsCraft internals) -->
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>5.14.2</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>5.14.2</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!--
                maven-shade-plugin
                ══════════════════
                compile-scope deps که داخل jar میشن (shaded):
                  • MongoDB driver  — storage=mongodb
                  • Javalin 6       — REST API embedded HTTP server
                  • Jackson         — JSON (Javalin transitive + BackupManager)
                  • Jetty           — Javalin's embedded servlet container
                  • Kotlin stdlib   — Javalin is written in Kotlin
                  • SLF4J + logback — Javalin logging (redirect به Bukkit logger)

                provided-scope deps (runtime از plugin.yml libraries لود میشن):
                  HikariCP, Jedis, SQLite, H2, MySQL, PostgreSQL

                هر lib که shade میشه باید relocate بشه تا با نسخه‌های
                دیگه پلاگین‌ها conflict نکنه.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <minimizeJar>false</minimizeJar>

                            <!-- ── Artifact filters ───────────────────────────
                                 excludes: signature files that break fat-jar loading
                                 (common with Bouncy Castle, AWS SDK, etc.)        -->
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>META-INF/MANIFEST.MF</exclude>
                                        <exclude>module-info.class</exclude>
                                    </excludes>
                                </filter>
                            </filters>

                            <!-- ── Transformers ──────────────────────────────
                                 ServicesResourceTransformer: merges META-INF/services
                                 files from multiple jars — needed by Jetty's SPI,
                                 Jackson's type factories, and SLF4J binding.       -->
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer"/>
                            </transformers>

                            <!-- ── Relocations ───────────────────────────────
                                 Every shaded lib gets its own sub-package under
                                 ir.permscraft.libs.* to prevent ClassLoader
                                 conflicts with other plugins that shade the same libs. -->
                            <relocations>

                                <!-- MongoDB -->
                                <relocation>
                                    <pattern>com.mongodb</pattern>
                                    <shadedPattern>ir.permscraft.libs.mongodb</shadedPattern>
                                </relocation>
                                <relocation>
                                    <pattern>org.bson</pattern>
                                    <shadedPattern>ir.permscraft.libs.bson</shadedPattern>
                                </relocation>

                                <!-- Javalin (Kotlin-based HTTP framework) -->
                                <relocation>
                                    <pattern>io.javalin</pattern>
                                    <shadedPattern>ir.permscraft.libs.javalin</shadedPattern>
                                </relocation>

                                <!-- Kotlin stdlib & reflection (Javalin dependency) -->
                                <relocation>
                                    <pattern>kotlin</pattern>
                                    <shadedPattern>ir.permscraft.libs.kotlin</shadedPattern>
                                </relocation>
                                <relocation>
                                    <pattern>kotlinx</pattern>
                                    <shadedPattern>ir.permscraft.libs.kotlinx</shadedPattern>
                                </relocation>

                                <!-- Jetty (Javalin's embedded web server) -->
                                <relocation>
                                    <pattern>org.eclipse.jetty</pattern>
                                    <shadedPattern>ir.permscraft.libs.jetty</shadedPattern>
                                </relocation>

                                <!-- Jackson (JSON — used by Javalin and BackupManager) -->
                                <relocation>
                                    <pattern>com.fasterxml.jackson</pattern>
                                    <shadedPattern>ir.permscraft.libs.jackson</shadedPattern>
                                </relocation>

                                <!-- SLF4J API (Javalin uses it for logging) -->
                                <relocation>
                                    <pattern>org.slf4j</pattern>
                                    <shadedPattern>ir.permscraft.libs.slf4j</shadedPattern>
                                </relocation>

                                <!-- Logback (default SLF4J backend bundled with Javalin) -->
                                <relocation>
                                    <pattern>ch.qos.logback</pattern>
                                    <shadedPattern>ir.permscraft.libs.logback</shadedPattern>
                                </relocation>


                                <!-- HikariCP (connection pool) -->
                                <relocation>
                                    <pattern>com.zaxxer.hikari</pattern>
                                    <shadedPattern>ir.permscraft.libs.hikari</shadedPattern>
                                </relocation>

                                <!-- Jedis (Redis client) + its deps -->
                                <relocation>
                                    <pattern>redis.clients</pattern>
                                    <shadedPattern>ir.permscraft.libs.jedis</shadedPattern>
                                </relocation>
                                <relocation>
                                    <pattern>org.apache.commons.pool2</pattern>
                                    <shadedPattern>ir.permscraft.libs.commons.pool2</shadedPattern>
                                </relocation>

                                <!-- SQLite JDBC -->
                                <relocation>
                                    <pattern>org.sqlite</pattern>
                                    <shadedPattern>ir.permscraft.libs.sqlite</shadedPattern>
                                </relocation>

                                <!-- H2 Database -->
                                <relocation>
                                    <pattern>org.h2</pattern>
                                    <shadedPattern>ir.permscraft.libs.h2</shadedPattern>
                                </relocation>

                                <!-- MySQL Connector/J -->
                                <relocation>
                                    <pattern>com.mysql</pattern>
                                    <shadedPattern>ir.permscraft.libs.mysql</shadedPattern>
                                </relocation>

                                <!-- MariaDB Connector/J -->
                                <relocation>
                                    <pattern>org.mariadb.jdbc</pattern>
                                    <shadedPattern>ir.permscraft.libs.mariadb</shadedPattern>
                                </relocation>

                                <!-- PostgreSQL JDBC -->
                                <relocation>
                                    <pattern>org.postgresql</pattern>
                                    <shadedPattern>ir.permscraft.libs.postgresql</shadedPattern>
                                </relocation>

                            </relocations>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Surefire: run JUnit 5 tests -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.1</version>
                <configuration>
                    <argLine>
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.util=ALL-UNNAMED
                        --add-opens java.base/java.time=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!-- Compiler plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <encoding>UTF-8</encoding>
                </configuration>
            </plugin>

        </plugins>

        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
    </build>

</project>
